# Copy this file to .env.local and fill in real values locally.
# Do not commit real API keys or secrets.

# Server-side GPT triage classification.
OPENAI_API_KEY=

# Server-side ElevenLabs API key. Never expose this with NEXT_PUBLIC_.
ELEVENLABS_API_KEY=

# Server-side ElevenLabs Conversational AI agent ID. Used by the signed-URL
# route at /api/elevenlabs/session so the agent id never reaches the browser.
ELEVENLABS_AGENT_ID=
